{
  "name": "badgenest-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "dotenv -e ../.env --override -- prisma db push",
    "seed:admin": "tsx src/scripts/promote-admin.ts",
    "generate:secrets": "node scripts/generate-secrets.mjs",
    "generate:jwt": "tsx src/scripts/issue-jwt.ts",
    "smoke:health": "tsx scripts/smoke-health.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.1",
    "uuid": "^9.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^9.0.0",
    "openapi-types": "^12.1.3",
    "prisma": "^6.6.0",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
