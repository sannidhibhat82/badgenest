<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS URL Rewrite: forward all requests to the Node API (must be listening on NODE_PORT, e.g. 3001).
  Prerequisites: IIS URL Rewrite module + (for outbound rules) Application Request Routing with proxy enabled.

  1. Create a site pointing at this folder (or place web.config in the API site root).
  2. Run the Node process (e.g. `node dist/server.js` via PM2, NSSM, or Windows Service).
  3. Set rewrite URL to match your Node listen address/port (default below: 127.0.0.1:3001).
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="BadgeNestAPIReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
