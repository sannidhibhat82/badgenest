# =============================================================================
# BadgeNest — copy to `.env` at the repository root (client + server read from here).
# =============================================================================

# --- Server (Express + Prisma) ---
PORT=3001

# Prisma SQL Server: use semicolon form and wrap the whole value in double quotes
# so `;` inside the URL is not parsed as multiple variables by dotenv.
# Password must match MSSQL_SA_PASSWORD in your SQL Server container/host.
#
# Example (Docker SQL Server on localhost:1433):
#   DATABASE_URL="sqlserver://localhost:1433;database=badgenest;user=sa;password=YourStrong!Password;encrypt=true;trustServerCertificate=true"
#
DATABASE_URL="sqlserver://localhost:1433;database=badgenest;user=sa;password=YOUR_SA_PASSWORD;encrypt=true;trustServerCertificate=true"

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# CORS + absolute links (email verification uses BACKEND_URL)
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3001

# Bootstrap first admin: POST /api/admin/promote with header x-bootstrap-secret
ADMIN_BOOTSTRAP_SECRET=replace-with-one-time-secret

# Optional: filesystem for uploads (default: server/public/uploads)
# UPLOAD_DIR=

# --- Email (optional). If any of HOST/USER/PASS/FROM is missing, verification is disabled. ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=BadgeNest <no-reply@example.com>
EMAIL_SECURE=false

# --- Client (Vite): required for production build; optional in dev (defaults to http://localhost:3001) ---
VITE_API_URL=http://localhost:3001

# --- Helpers (run from repo root) ---
# npm run generate:secrets
# npm run generate:jwt -- --email=you@example.com --admin
