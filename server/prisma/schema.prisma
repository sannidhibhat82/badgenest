// BadgeNest — maps to existing SQL Server tables (see server/database/schema.sql).
// Use `prisma db push` against an empty database, or apply schema.sql manually then `prisma generate`.

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String    @id @db.UniqueIdentifier
  email           String    @unique @db.NVarChar(255)
  passwordHash    String    @map("password_hash") @db.NVarChar(255)
  emailVerified   Boolean   @default(false) @map("email_verified")
  fullName        String?   @map("full_name") @db.NVarChar(500)
  avatarUrl       String?   @map("avatar_url") @db.NVarChar(2048)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  roles               UserRole[]
  recipientAssertions Assertion[]           @relation("AssertionRecipient")
  apiKeys             ApiKey[]              @relation("ApiKeyCreator")
  webhooks            Webhook[]             @relation("WebhookCreator")
  auditLogsAsActor    AuditLog[]            @relation("AuditActor")
  invitesSent         BadgeInvite[]         @relation("InviteInviter")
  invitesClaimed      BadgeInvite[]         @relation("InviteClaimedBy")
  notifications       Notification[]
  emailVerifications  EmailVerification[]
  profileTags         ProfileTag[]

  @@map("users")
}

model UserRole {
  id     String @id @db.UniqueIdentifier
  userId String @map("user_id") @db.UniqueIdentifier
  role   String @default("learner") @db.NVarChar(50)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Issuer {
  id          String   @id @db.UniqueIdentifier
  name        String   @db.NVarChar(500)
  description String?  @db.NVarChar(4000)
  email       String?  @db.NVarChar(255)
  website     String?  @db.NVarChar(2048)
  logoUrl     String?  @map("logo_url") @db.NVarChar(2048)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  badgeClasses BadgeClass[]

  @@map("issuers")
}

model BadgeClass {
  id          String   @id @db.UniqueIdentifier
  issuerId    String   @map("issuer_id") @db.UniqueIdentifier
  name        String   @db.NVarChar(500)
  description String?  @db.NVarChar(4000)
  imageUrl    String?  @map("image_url") @db.NVarChar(2048)
  criteria    String?  @db.NVarChar(4000)
  expiryDays  Int?     @map("expiry_days")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  issuer      Issuer        @relation(fields: [issuerId], references: [id], onDelete: Cascade)
  assertions  Assertion[]
  invites     BadgeInvite[]
  junctions   BadgeClassCategory[]

  @@map("badge_classes")
}

model Assertion {
  id                 String    @id @db.UniqueIdentifier
  badgeClassId       String    @map("badge_class_id") @db.UniqueIdentifier
  recipientId        String    @map("recipient_id") @db.UniqueIdentifier
  issuedAt           DateTime  @default(now()) @map("issued_at")
  expiresAt          DateTime? @map("expires_at")
  evidenceUrl        String?   @map("evidence_url") @db.NVarChar(2048)
  revoked            Boolean   @default(false)
  revocationReason   String?   @map("revocation_reason") @db.NVarChar(4000)
  signature          String?   @db.NVarChar(4000)
  snapshotJson       String?   @map("snapshot_json") @db.NVarChar(4000)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  badgeClass BadgeClass  @relation(fields: [badgeClassId], references: [id], onDelete: Cascade)
  recipient  User        @relation("AssertionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  views      BadgeView[]

  @@map("assertions")
}

model Tag {
  id          String       @id @db.UniqueIdentifier
  name        String       @unique @db.NVarChar(255)
  color       String       @default("#6366f1") @db.NVarChar(50)
  createdAt   DateTime     @default(now()) @map("created_at")
  profileTags ProfileTag[]

  @@map("tags")
}

model ProfileTag {
  id            String   @id @db.UniqueIdentifier
  profileUserId String   @map("profile_user_id") @db.UniqueIdentifier
  tagId         String   @map("tag_id") @db.UniqueIdentifier
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [profileUserId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([profileUserId, tagId])
  @@map("profile_tags")
}

model ApiKey {
  id          String    @id @db.UniqueIdentifier
  keyHash     String    @map("key_hash") @db.NVarChar(255)
  keyPrefix   String    @map("key_prefix") @db.NVarChar(20)
  name        String    @db.NVarChar(255)
  createdBy   String    @map("created_by") @db.UniqueIdentifier
  permissions String?   @db.NVarChar(4000)
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  creator User @relation("ApiKeyCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Webhook {
  id              String    @id @db.UniqueIdentifier
  url             String    @db.NVarChar(2048)
  events          String    @db.NVarChar(4000)
  secret          String    @db.NVarChar(255)
  active          Boolean   @default(true)
  createdBy       String    @map("created_by") @db.UniqueIdentifier
  failureCount    Int       @default(0) @map("failure_count")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  creator User @relation("WebhookCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

model AuditLog {
  id         String   @id @db.UniqueIdentifier
  actorId    String   @map("actor_id") @db.UniqueIdentifier
  action     String   @db.NVarChar(255)
  entityType String   @map("entity_type") @db.NVarChar(255)
  entityId   String?  @map("entity_id") @db.UniqueIdentifier
  details    String?  @db.NVarChar(4000)
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model BadgeInvite {
  id           String    @id @db.UniqueIdentifier
  badgeClassId String    @map("badge_class_id") @db.UniqueIdentifier
  email        String    @db.NVarChar(255)
  inviteToken  String    @map("invite_token") @db.NVarChar(255)
  status       String    @default("pending") @db.NVarChar(50)
  invitedBy    String    @map("invited_by") @db.UniqueIdentifier
  claimedBy    String?   @map("claimed_by") @db.UniqueIdentifier
  claimedAt    DateTime? @map("claimed_at")
  evidenceUrl  String?   @map("evidence_url") @db.NVarChar(2048)
  createdAt    DateTime  @default(now()) @map("created_at")

  badgeClass BadgeClass @relation(fields: [badgeClassId], references: [id], onDelete: Cascade)
  inviter    User       @relation("InviteInviter", fields: [invitedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  claimer    User?      @relation("InviteClaimedBy", fields: [claimedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("badge_invites")
}

model BadgeCategory {
  id          String   @id @db.UniqueIdentifier
  name        String   @db.NVarChar(255)
  color       String?  @db.NVarChar(50)
  description String?  @db.NVarChar(4000)
  createdAt   DateTime @default(now()) @map("created_at")

  classLinks BadgeClassCategory[]

  @@map("badge_categories")
}

model BadgeClassCategory {
  id           String @id @db.UniqueIdentifier
  badgeClassId String @map("badge_class_id") @db.UniqueIdentifier
  categoryId   String @map("category_id") @db.UniqueIdentifier

  badgeClass BadgeClass    @relation(fields: [badgeClassId], references: [id], onDelete: Cascade)
  category   BadgeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([badgeClassId, categoryId])
  @@map("badge_class_categories")
}

model BadgeView {
  id          String   @id @db.UniqueIdentifier
  assertionId String   @map("assertion_id") @db.UniqueIdentifier
  viewedAt    DateTime @default(now()) @map("viewed_at")
  viewerHash  String?  @map("viewer_hash") @db.NVarChar(255)

  assertion Assertion @relation(fields: [assertionId], references: [id], onDelete: Cascade)

  @@map("badge_views")
}

model Notification {
  id        String   @id @db.UniqueIdentifier
  userId    String   @map("user_id") @db.UniqueIdentifier
  title     String   @db.NVarChar(500)
  message   String   @db.NVarChar(4000)
  read      Boolean  @default(false) @map("read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model EmailVerification {
  id        String    @id @db.UniqueIdentifier
  userId    String    @map("user_id") @db.UniqueIdentifier
  tokenHash String    @unique @map("token_hash") @db.NVarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}
